{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@stashy/shared$": "<rootDir>/../../../shared/src",
    "^@stashy/shared/(.*)$": "<rootDir>/../../../shared/src/$1"
  }
}
