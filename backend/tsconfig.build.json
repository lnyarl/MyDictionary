{
  "extends": "./tsconfig.json",
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",
    "paths": {
      "@shared": ["../shared/src"],
      "@shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"], // shared를 직접 포함하지 않음
  "references": [
    { "path": "../shared" } // shared 프로젝트를 참조로 추가
  ]
}
