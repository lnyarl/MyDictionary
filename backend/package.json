{
  "name": "stashy-backend",
  "version": "1.0.0",
  "description": "Stashy Backend API",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "start": "nest start",
    "dev": "cd ../shared && yarn build && cd ../backend && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/backend/src/main",
    "lint": "biome lint --write .",
    "lint:check": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:cov": "jest --coverage --runInBand",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./src/test/jest-e2e.json --runInBand",
    "test:docker:up": "docker compose -f ../docker-compose.test.yml up -d --wait",
    "test:docker:down": "docker compose -f ../docker-compose.test.yml down",
    "test:ci": "yarn test:docker:up && jest --runInBand --forceExit; yarn test:docker:down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@stashy/shared": "*",
    "@types/ioredis": "^5.0.0",
    "@types/knex": "^0.16.1",
    "@types/uuid": "^11.0.0",
    "bullmq": "^5.67.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.9.2",
    "knex": "^3.1.0",
    "nestjs-i18n": "10.5.0",
    "open-graph-scraper": "^6.11.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "9.0.1",
    "uuidv7": "^1.1.0",
    "wtfnode": "^0.10.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.dto.ts",
      "!**/*.entity.ts",
      "!**/*.module.ts",
      "!**/*.controller.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@stashy/shared$": "<rootDir>/../../shared/src",
      "^@stashy/shared/(.*)$": "<rootDir>/../../shared/src/$1"
    },
    "globalSetup": "<rootDir>/test/global-setup.ts",
    "globalTeardown": "<rootDir>/test/global-teardown.ts",
    "testTimeout": 30000
  }
}
