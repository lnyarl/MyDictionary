# frontend-admin빌드하는것 말고는 Dockerfile과 모두 똑같아야 한다.

# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Copy root package files
COPY package.json yarn.lock ./

# Copy all workspace package files to satisfy yarn install
COPY shared/package.json ./shared/
COPY frontend/package.json ./frontend/
COPY backend/package.json ./backend/
COPY frontend-admin/package.json ./frontend-admin/
COPY backend-admin/package.json ./backend-admin/

# Install dependencies
RUN yarn install --frozen-lockfile

# Copy source code for shared and the target app
COPY shared/ ./shared/
COPY frontend-admin/ ./frontend-admin/

# Build shared first
RUN yarn workspace @stashy/shared build

# Build frontend-admin
RUN yarn workspace stashy-frontend-admin build:dev

# Production stage
FROM nginx:alpine

# Copy nginx configuration
COPY frontend-admin/nginx.conf.template /etc/nginx/templates/default.conf.template

# Copy built application from builder
COPY --from=builder /app/frontend-admin/dist /usr/share/nginx/html

# Expose port
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
