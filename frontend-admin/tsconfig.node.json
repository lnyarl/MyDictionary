{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"noEmit": true,
		"paths": {
			"@stashy/shared": ["../shared/src"],
			"@stashy/shared/*": ["../shared/src/*"]
		}
	},
	"include": ["vite.config.ts"],
	"references": [{ "path": "../shared" }]
}
