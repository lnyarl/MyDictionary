# Application
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://yourdomain.com
ADMIN_FRONTEND_URL=https://admin.yourdomain.com

# Google Sign-In
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=8h

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=mystashy
DB_PASSWORD=your_db_password
DB_DATABASE=stashy

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Object Storage (MinIO)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://minio:9000
PUBLIC_STORAGE_ENDPOINT=https://storage.yourdomain.com
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_minio_access_key
STORAGE_SECRET_KEY=your_minio_secret_key
STORAGE_BUCKET=stashy-bucket
STORAGE_TEMP_BUCKET=stashy-temp-bucket

# Docker Compose infrastructure vars
DOMAIN=yourdomain.com
CERTBOT_EMAIL=your-email@example.com
MINIO_ROOT_USER=your_minio_root_user
MINIO_ROOT_PASSWORD=your_minio_root_password
NAMECHEAP_DDNS_PASSWORD=your_namecheap_ddns_password
